{
  "name": "tallerpro-enterprise",
  "version": "2.1.0",
  "description": "Sistema de gestión integral para talleres mecánicos — Guatemala",
  "main": "electron/main.js",
  "author": "CM Telecomm GT",
  "license": "ISC",
  "homepage": "https://app.cmtelecommgt.com",
  "scripts": {
    "start":    "electron .",
    "build":    "electron-builder --win",
    "build:mac":"electron-builder --mac",
    "pack":     "electron-builder --dir"
  },
  "build": {
    "appId":          "com.cmtelecommgt.tallerpro",
    "productName":    "TallerPro Enterprise",
    "copyright":      "© 2026 CM Telecomm GT",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon":          "icons/icon-512.png",
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick":           false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon":      "icons/icon-512.png",
      "uninstallerIcon":    "icons/icon-512.png",
      "installerHeaderIcon":"icons/icon-512.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName":       "TallerPro Enterprise",
      "license":            "LICENSE.txt"
    },
    "files": [
      "electron/**/*",
      "icons/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron":         "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
